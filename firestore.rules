rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public digital menu: anyone can read every branch's categories,
    // products and settings so the site works without logging in. Writes
    // are restricted to signed-in admin users (this project has a single
    // admin login, not per-document ownership).
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /products/{productId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /siteSettings/{settingsId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /themeSettings/{settingsId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /contactSettings/{settingsId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /branches/{branchId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if request.auth != null;

        match /products/{productId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
      }

      match /settings/{settingsId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Deny anything outside the shapes above by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
